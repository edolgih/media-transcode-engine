{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/media-transcode-engine-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 1,
          "shared": true
        }
      }
    ]
  },
  "RuntimeValues": {
    "FfprobePath": "ffprobe",
    "FfmpegPath": "ffmpeg"
  }
}
