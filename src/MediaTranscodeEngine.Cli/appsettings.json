{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/media-transcode-engine-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 1,
          "shared": true
        }
      }
    ]
  },
  "RuntimeValues": {
    "ProfilesYamlPath": "Profiles/ToMkvGPU.576.Profiles.yaml",
    "FfprobePath": "ffprobe",
    "FfmpegPath": "ffmpeg",
    "ProcessTimeoutMs": 30000,
    "SampleEncodeInactivityTimeoutMs": 12000,
    "SampleDurationSeconds": 15,
    "SampleEncodeMaxRetries": 0,
    "AutoSampleNvencPreset": "p6"
  }
}
